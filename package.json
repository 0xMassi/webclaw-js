{
  "name": "@webclaw/sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for the Webclaw web extraction API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xMassi/webclaw-js.git"
  },
  "homepage": "https://webclaw.io",
  "bugs": {
    "url": "https://github.com/0xMassi/webclaw-js/issues"
  },
  "keywords": [
    "webclaw",
    "web-scraping",
    "scraper",
    "crawl",
    "extract",
    "llm",
    "ai"
  ],
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}